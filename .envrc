# We don't auto-load `nix develop` here because it's slow and blocks the shell.
# Run `nix develop` manually to get the pre-commit hooks and dev tooling.
# This .envrc just warns you when you're in this repo without having done so.

if [ -z "${IN_NIX_SHELL:-}" ]; then
	echo "Note: run 'nix develop' to load pre-commit hooks and dev tools."
	export PS1="[nix develop?] ${PS1:-\$ }"
fi

source_env_if_exists .envrc.private
